# Copy to .env (or .env.local) and adjust for your environment.

# Base URL of the local FastAPI sidecar. Leave EMPTY for the packaged/preview app (the SPA is
# served same-origin). For `vite dev` against a separately-run server, use http://localhost:8756.
VITE_API_BASE=

# Not used locally (the sidecar requires no auth); kept for SPA compatibility.
VITE_API_TOKEN=local
