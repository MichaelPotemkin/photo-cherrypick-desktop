{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Folder dialog + sidecar server spawn for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "cull-server", "sidecar": true }]
    }
  ]
}
