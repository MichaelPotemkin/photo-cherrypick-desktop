{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photo Cherrypick",
  "version": "1.0.7",
  "identifier": "dev.photocherrypick.desktop",
  "build": {
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["bin/cull-server"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MichaelPotemkin/photo-cherrypick-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3RTQ3QTFBNkExRjRDNkYKUldSdlRCOXFHbnJrZDJjT3JoaXB2UFF4RWw3RHQ5NHVFVGJvZmtrM051anN5WTdEMGRXS1BuOVMK"
    }
  }
}
