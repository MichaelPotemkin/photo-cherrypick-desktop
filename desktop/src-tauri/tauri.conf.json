{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photo Cherrypick",
  "version": "0.1.0",
  "identifier": "dev.photocherrypick.desktop",
  "build": {
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["bin/cull-server"],
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
